{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pytest: Full",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-vv"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pytest: Fast (not slow)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-m",
                "not slow",
                "-vv"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pytest: Slow only",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-m",
                "slow",
                "-vv"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
